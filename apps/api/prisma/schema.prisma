// Mozaika — schemat bazy danych (Prisma).
// Uniwersalna tabela Media (pole `type`) pozwala oceniać wszystkie media
// w jednej strukturze. Recenzje (Review) łączą użytkownika z tytułem i oceną.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler transakcyjny (aplikacja)
  directUrl = env("DIRECT_URL") // połączenie bezpośrednie (migracje)
}

/// Rodzaj tytułu — dzięki temu jedna tabela `Media` obsługuje wszystko.
enum MediaType {
  FILM
  SERIAL
  KSIAZKA
  GRA
  MUZYKA
  MANGA
  ANIME
}

/// Użytkownik platformy (autor recenzji).
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  displayName  String
  passwordHash String? // scrypt: "salt:hash"; null dla starych kont demo
  avatarUrl    String? // zdjęcie profilowe jako data:image (skompresowane ~256px)
  createdAt    DateTime @default(now())

  reviews   Review[]
  watchlist WatchlistItem[]
  following Follow[]        @relation("following") // kogo ja obserwuję
  followers Follow[]        @relation("followers") // kto obserwuje mnie
}

/// Obserwowanie (znajomi) — kierunkowe: follower obserwuje followed.
model Follow {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  follower   User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followerId Int

  followed   User @relation("followers", fields: [followedId], references: [id], onDelete: Cascade)
  followedId Int

  @@unique([followerId, followedId])
}

/// Tytuł do oceniania (film, serial, książka, gra, muzyka).
model Media {
  id         Int       @id @default(autoincrement())
  type       MediaType
  title      String
  externalId String? // np. ID z TMDB — żeby nie dublować tego samego tytułu
  year       Int?
  posterUrl  String?
  createdAt  DateTime  @default(now())

  reviews   Review[]
  watchlist WatchlistItem[]

  // Ten sam tytuł z tego samego źródła nie może istnieć dwa razy.
  @@unique([type, externalId])
}

/// Recenzja: ocena (1–10) danego tytułu przez danego użytkownika.
model Review {
  id        Int      @id @default(autoincrement())
  rating    Float // 0.5–10 (co 0.5 — półgwiazdki)
  text      String?
  favorite  Boolean  @default(false) // przypięte do TOP 4 na profilu
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  // Jeden użytkownik = jedna ocena danego tytułu.
  @@unique([userId, mediaId])
}

/// Lista „do obejrzenia/zagrania" — tytuły, które user chce sprawdzić później.
model WatchlistItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  @@unique([userId, mediaId])
}
