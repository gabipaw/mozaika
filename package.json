{
  "name": "mozaika",
  "version": "0.1.0",
  "private": true,
  "description": "Mozaika — platforma recenzji wszystkich mediów. Monorepo (Turborepo).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dupcheck": "jscpd apps",
    "secretcheck": "secretlint \"**/*\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "secretlint"
    ],
    "*.ts": [
      "eslint",
      "prettier --check"
    ],
    "*.{js,mjs,json,md}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "secretlint": "^13.0.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  },
  "packageManager": "npm@9.2.0"
}
