// Mozaika — schemat bazy danych (Prisma).
// Uniwersalna tabela Media (pole `type`) pozwala oceniać wszystkie media
// w jednej strukturze. Recenzje (Review) łączą użytkownika z tytułem i oceną.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler transakcyjny (aplikacja)
  directUrl = env("DIRECT_URL") // połączenie bezpośrednie (migracje)
}

/// Rodzaj tytułu — dzięki temu jedna tabela `Media` obsługuje wszystko.
enum MediaType {
  FILM
  SERIAL
  KSIAZKA
  GRA
  MUZYKA
  MANGA
  ANIME
}

/// Status ocenionego tytułu w katalogu. „Plan" (chcę obejrzeć) to osobna lista
/// (WatchlistItem), więc tu wystarczą dwa stany. Domyślnie DONE — istniejące oceny
/// to tytuły już obejrzane/przeczytane.
enum ReviewStatus {
  IN_PROGRESS
  DONE
}

/// Użytkownik platformy (autor recenzji).
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  displayName  String
  passwordHash String? // scrypt: "salt:hash"; null dla starych kont demo
  avatarUrl    String? // zdjęcie profilowe jako data:image (skompresowane ~256px)
  bio          String? // krótki opis „o mnie" na profilu (do 200 znaków)
  title        String? // wybrany „tytuł" do pokazania przy imieniu (odblokowany osiągnięciami)
  mutedNotifs  String[] @default([]) // wyciszone typy powiadomień (np. "like","follow")
  createdAt    DateTime @default(now())

  reviews          Review[]
  watchlist        WatchlistItem[]
  lists            List[] // własne listy/kolekcje tytułów
  following        Follow[]           @relation("following") // kogo ja obserwuję
  followers        Follow[]           @relation("followers") // kto obserwuje mnie
  pushSubs         PushSubscription[]
  reactions        ReviewReaction[] // moje reakcje na cudze recenzje
  sentMessages     Message[]          @relation("sentMessages")
  receivedMessages Message[]          @relation("receivedMessages")
  messageReactions MessageReaction[]
  notifications    Notification[]     @relation("notifRecipient") // powiadomienia dla mnie
  actedNotifs      Notification[]     @relation("notifActor") // powiadomienia, które wywołałem
  reviewComments   ReviewComment[] // moje komentarze pod recenzjami
  blocking         Block[]            @relation("blocker") // kogo ja zablokowałem
  blockedBy        Block[]            @relation("blocked") // kto zablokował mnie
}

/// Blokada: `blocker` nie chce mieć nic wspólnego z `blocked`. Blokada jest
/// jednokierunkowa w zapisie, ale skutki liczymy obustronnie (patrz isBlocked):
/// zrywa wzajemną obserwację (koniec czatu) i odbiera prawo do komentowania.
model Block {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  blocker   User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId Int
  blocked   User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedId Int

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

/// Komentarz pod recenzją. `parentId != null` = odpowiedź na inny komentarz
/// (jeden poziom zagnieżdżenia — odpowiedzi lecą pod komentarzem nadrzędnym).
/// Usunięcie miękkie (deletedAt), żeby odpowiedzi pod usuniętym nie znikały.
model ReviewComment {
  id        Int       @id @default(autoincrement())
  text      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId Int

  parent   ReviewComment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  replies  ReviewComment[] @relation("replies")

  @@index([reviewId])
  @@index([parentId])
}

/// Powiadomienie w centrum powiadomień (follow / polubienie recenzji / ocena z listy).
model Notification {
  id        Int       @id @default(autoincrement())
  type      String // "follow" | "like" | "watchlist_rated" | "premiere" | "comment" | "reply"
  createdAt DateTime  @default(now())
  readAt    DateTime?
  reviewId  Int? // dla type=like (bez FK — recenzja bywa usuwana, powiadomienie zostaje)

  user    User   @relation("notifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  userId  Int // odbiorca
  actor   User?  @relation("notifActor", fields: [actorId], references: [id], onDelete: Cascade)
  actorId Int? // kto wywołał; null = powiadomienie systemowe (premiera)
  media   Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId Int?

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// Wiadomość 1:1 w czacie. API pozwala pisać tylko przy WZAJEMNEJ obserwacji.
model Message {
  id        Int       @id @default(autoincrement())
  text      String    @default("") // może być puste, gdy wiadomość to zdjęcie/karta tytułu
  imageUrl  String? // zdjęcie jako data:image (skompresowane po stronie klienta)
  createdAt DateTime  @default(now())
  readAt    DateTime? // null = jeszcze nieprzeczytana przez odbiorcę
  deletedAt DateTime? // null = normalna; ustawione = usunięta (miękko, treść czyścimy)
  editedAt  DateTime? // ustawione = wiadomość edytowana

  sender     User              @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderId   Int
  receiver   User              @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId Int
  media      Media?            @relation(fields: [mediaId], references: [id], onDelete: SetNull) // udostępniony tytuł
  mediaId    Int?
  reactions  MessageReaction[]

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, readAt])
  @@index([mediaId])
}

/// Reakcja emoji na wiadomość (jedna na użytkownika na wiadomość).
model MessageReaction {
  id        Int      @id @default(autoincrement())
  emoji     String
  createdAt DateTime @default(now())

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  @@unique([messageId, userId])
  @@index([messageId])
}

/// Subskrypcja Web Push (jedna na urządzenie/przeglądarkę — user może mieć kilka).
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique // adres bramki push (unikalny per urządzenie)
  p256dh    String // klucz publiczny przeglądarki (szyfrowanie ładunku)
  auth      String // sekret uwierzytelniający przeglądarki
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@index([userId])
}

/// Obserwowanie (znajomi) — kierunkowe: follower obserwuje followed.
model Follow {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  follower   User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followerId Int

  followed   User @relation("followers", fields: [followedId], references: [id], onDelete: Cascade)
  followedId Int

  @@unique([followerId, followedId])
}

/// Tytuł do oceniania (film, serial, książka, gra, muzyka).
model Media {
  id               Int       @id @default(autoincrement())
  type             MediaType
  title            String
  externalId       String? // np. ID z TMDB — żeby nie dublować tego samego tytułu
  year             Int?
  posterUrl        String?
  genres           String[]  @default([]) // gatunki (np. Sci-Fi, Horror) — do afinności gustu
  releaseDate      DateTime? // premiera wg TMDB/AniList/RAWG — do powiadomień o premierach
  releaseCheckedAt DateTime? // kiedy ostatnio pytaliśmy API o datę (żeby nie pytać co dzień)
  createdAt        DateTime  @default(now())

  reviews       Review[]
  watchlist     WatchlistItem[]
  listItems     ListItem[] // obecność na własnych listach użytkowników
  messages      Message[] // udostępnienia tego tytułu w czacie
  notifications Notification[]

  // Ten sam tytuł z tego samego źródła nie może istnieć dwa razy.
  @@unique([type, externalId])
}

/// Recenzja: ocena (1–10) danego tytułu przez danego użytkownika.
model Review {
  id        Int          @id @default(autoincrement())
  rating    Float // 0.5–10 (co 0.5 — półgwiazdki)
  text      String?
  favorite  Boolean      @default(false) // przypięte do TOP 4 na profilu
  status    ReviewStatus @default(DONE) // W trakcie / Ukończone (Plan = watchlista)
  createdAt DateTime     @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  reactions ReviewReaction[]
  comments  ReviewComment[]

  // Jeden użytkownik = jedna ocena danego tytułu.
  @@unique([userId, mediaId])
}

/// Reakcja na cudzą recenzję: serce (value = 1) albo kciuk w dół (value = -1).
/// Na własną recenzję zareagować się nie da.
/// Tabela w bazie nazywa się jeszcze „ReviewLike" (@@map) — powstała, gdy istniały
/// same polubienia; zmiana nazwy tabeli nic by nie dała poza ryzykiem przy deployu.
model ReviewReaction {
  id        Int      @id @default(autoincrement())
  value     Int      @default(1) // 1 = serce, -1 = kciuk w dół
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId Int

  // Jeden użytkownik = jedna reakcja na daną recenzję (serce ALBO kciuk, nie oba).
  @@unique([userId, reviewId])
  @@index([reviewId])
  @@map("ReviewLike")
}

/// Lista „do obejrzenia/zagrania" — tytuły, które user chce sprawdzić później.
model WatchlistItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  // Push o premierze tego tytułu został już rozstrzygnięty: albo wysłany, albo
  // świadomie pominięty (tytuł był wydany, zanim trafił na listę). Null = czekamy.
  premiereNotifiedAt DateTime?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  @@unique([userId, mediaId])
}

/// Własna lista/kolekcja tytułów użytkownika (np. „Najlepsze 2024"). `isPublic` decyduje,
/// czy widać ją na profilu dla innych. Nazwy mogą się powtarzać (brak unikalności).
model List {
  id        Int      @id @default(autoincrement())
  name      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  items ListItem[]

  @@index([userId])
}

/// Pozycja na liście — powiązanie listy z tytułem. Jeden tytuł raz na listę.
model ListItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  list   List @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  @@unique([listId, mediaId])
  @@index([mediaId])
}
