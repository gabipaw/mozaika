// Mozaika — schemat bazy danych (Prisma).
// Uniwersalna tabela Media (pole `type`) pozwala oceniać wszystkie media
// w jednej strukturze. Recenzje (Review) łączą użytkownika z tytułem i oceną.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler transakcyjny (aplikacja)
  directUrl = env("DIRECT_URL") // połączenie bezpośrednie (migracje)
}

/// Rodzaj tytułu — dzięki temu jedna tabela `Media` obsługuje wszystko.
enum MediaType {
  FILM
  SERIAL
  KSIAZKA
  GRA
  MUZYKA
  MANGA
  ANIME
}

/// Użytkownik platformy (autor recenzji).
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  displayName  String
  passwordHash String? // scrypt: "salt:hash"; null dla starych kont demo
  avatarUrl    String? // zdjęcie profilowe jako data:image (skompresowane ~256px)
  createdAt    DateTime @default(now())

  reviews     Review[]
  watchlist   WatchlistItem[]
  following   Follow[]           @relation("following") // kogo ja obserwuję
  followers   Follow[]           @relation("followers") // kto obserwuje mnie
  pushSubs    PushSubscription[]
  reactions   ReviewReaction[] // moje reakcje na cudze recenzje
  sentMessages     Message[] @relation("sentMessages")
  receivedMessages Message[] @relation("receivedMessages")
}

/// Wiadomość 1:1 w czacie. API pozwala pisać tylko przy WZAJEMNEJ obserwacji.
model Message {
  id         Int       @id @default(autoincrement())
  text       String
  createdAt  DateTime  @default(now())
  readAt     DateTime? // null = jeszcze nieprzeczytana przez odbiorcę

  sender     User @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderId   Int
  receiver   User @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId Int

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, readAt])
}

/// Subskrypcja Web Push (jedna na urządzenie/przeglądarkę — user może mieć kilka).
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique // adres bramki push (unikalny per urządzenie)
  p256dh    String // klucz publiczny przeglądarki (szyfrowanie ładunku)
  auth      String // sekret uwierzytelniający przeglądarki
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@index([userId])
}

/// Obserwowanie (znajomi) — kierunkowe: follower obserwuje followed.
model Follow {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  follower   User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followerId Int

  followed   User @relation("followers", fields: [followedId], references: [id], onDelete: Cascade)
  followedId Int

  @@unique([followerId, followedId])
}

/// Tytuł do oceniania (film, serial, książka, gra, muzyka).
model Media {
  id               Int       @id @default(autoincrement())
  type             MediaType
  title            String
  externalId       String? // np. ID z TMDB — żeby nie dublować tego samego tytułu
  year             Int?
  posterUrl        String?
  genres           String[]  @default([]) // gatunki (np. Sci-Fi, Horror) — do afinności gustu
  releaseDate      DateTime? // premiera wg TMDB/AniList/RAWG — do powiadomień o premierach
  releaseCheckedAt DateTime? // kiedy ostatnio pytaliśmy API o datę (żeby nie pytać co dzień)
  createdAt        DateTime  @default(now())

  reviews   Review[]
  watchlist WatchlistItem[]

  // Ten sam tytuł z tego samego źródła nie może istnieć dwa razy.
  @@unique([type, externalId])
}

/// Recenzja: ocena (1–10) danego tytułu przez danego użytkownika.
model Review {
  id        Int      @id @default(autoincrement())
  rating    Float // 0.5–10 (co 0.5 — półgwiazdki)
  text      String?
  favorite  Boolean  @default(false) // przypięte do TOP 4 na profilu
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  reactions ReviewReaction[]

  // Jeden użytkownik = jedna ocena danego tytułu.
  @@unique([userId, mediaId])
}

/// Reakcja na cudzą recenzję: serce (value = 1) albo kciuk w dół (value = -1).
/// Na własną recenzję zareagować się nie da.
/// Tabela w bazie nazywa się jeszcze „ReviewLike" (@@map) — powstała, gdy istniały
/// same polubienia; zmiana nazwy tabeli nic by nie dała poza ryzykiem przy deployu.
model ReviewReaction {
  id        Int      @id @default(autoincrement())
  value     Int      @default(1) // 1 = serce, -1 = kciuk w dół
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId Int

  // Jeden użytkownik = jedna reakcja na daną recenzję (serce ALBO kciuk, nie oba).
  @@unique([userId, reviewId])
  @@index([reviewId])
  @@map("ReviewLike")
}

/// Lista „do obejrzenia/zagrania" — tytuły, które user chce sprawdzić później.
model WatchlistItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  // Push o premierze tego tytułu został już rozstrzygnięty: albo wysłany, albo
  // świadomie pominięty (tytuł był wydany, zanim trafił na listę). Null = czekamy.
  premiereNotifiedAt DateTime?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId Int

  @@unique([userId, mediaId])
}
